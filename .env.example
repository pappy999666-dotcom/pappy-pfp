# ─────────────────────────────────────────────────────────────────────────────
# PAPPY PFP V3 — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=

# Telegram user ID(s) of bot owner(s), comma-separated
# Example: OWNER_ID=123456789,987654321
OWNER_ID=

# MongoDB connection string (Atlas or self-hosted)
# Leave empty to use in-memory MongoDB (data resets on restart)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/pappybot

# Redis connection string (required for auto-change scheduler)
# Leave empty to disable BullMQ scheduler (bot still runs without it)
REDIS_URL=redis://localhost:6379

# ── WhatsApp ──────────────────────────────────────────────────────────────────

# Owner's WhatsApp number (international format, no + or spaces)
# Example: OWNER_WA_NUMBER=2348012345678
OWNER_WA_NUMBER=

# ── API Keys (optional — used for wallpaper search fallbacks) ─────────────────

# Unsplash API key — https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Pexels API key — https://www.pexels.com/api/
PEXELS_API_KEY=

# OpenRouter API key — https://openrouter.ai/keys
# Required for /imagine (AI Image Generator)
OPENROUTER_API_KEY=

# ── Security ──────────────────────────────────────────────────────────────────

# Secret key for AES-256-GCM session encryption (change this!)
SESSION_SECRET=change-me-to-a-random-secret-string

# ── Optional ──────────────────────────────────────────────────────────────────

# Pre-configured Telegram channel ID or @username for wallpaper drops
TELEGRAM_CHANNEL=

# Pre-configured WhatsApp channel JID for wallpaper drops
WHATSAPP_CHANNEL=

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Node environment: development | production (default: development)
NODE_ENV=production
